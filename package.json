{
  "name": "@0xdolan/tsroj",
  "version": "1.0.3",
  "description": "The definitive TypeScript library for the Kurdish solar calendar.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
