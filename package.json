    "lint": "biome check src/ tests/",
    "lint:fix": "biome check --write src/ tests/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/0xdolan/tsroj.git"
  },
  "bugs": {
    "url": "https://github.com/0xdolan/tsroj/issues"
  },
  "homepage": "https://github.com/0xdolan/tsroj#readme",
  "keywords": [
    "kurdish",
    "calendar",
    "date",
    "roj",
    "datetime",
    "solar"
  ],
  "author": "",
  "license": "GPL-3.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  }
}
