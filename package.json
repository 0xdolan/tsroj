{
  "name": "@0xdolan/tsroj",
  "version": "1.0.1",
  "description": "The definitive TypeScript library for the Kurdish solar calendar.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "build:demo": "npm run build --prefix demo",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && biome check src tests",
    "format": "biome format --write src tests",
    "ci": "npm run lint && npm run test && npm run build && npm run build:demo"
  },
  "keywords": [
    "kurdish",
    "calendar",
    "date",
    "roj",
    "datetime",
    "solar"
  ],
  "author": "",
  "license": "GPL-3.0",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
